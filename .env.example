# ============================================================
# Smart Insole — Environment Variables
# Sao chép file này thành .env rồi chỉnh giá trị cho phù hợp:
#   cp .env.example .env
# KHÔNG commit file .env lên Git.
# ============================================================


# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
# Format: postgresql://user:password@host:port/dbname
# Khi chạy Docker Compose: host = tên service = "postgres"
# Khi chạy local (ngoài Docker): host = localhost
POSTGRES_URL=postgresql://smartinsole:smartinsole_pass@postgres:5432/smartinsole


# ------------------------------------------------------------
# InfluxDB
# ------------------------------------------------------------
# URL của InfluxDB service (Docker Compose: "influxdb")
INFLUXDB_URL=http://influxdb:8086

# Token tạo trong InfluxDB UI → Load Data → API Tokens
# Giá trị dưới đây khớp với DOCKER_INFLUXDB_INIT_ADMIN_TOKEN
INFLUXDB_TOKEN=smart-insole-dev-token-change-in-production

# Organization và Bucket — phải khớp với biến DOCKER_INFLUXDB_INIT_* bên dưới
INFLUXDB_ORG=smartinsole
INFLUXDB_BUCKET=sensor_data


# ------------------------------------------------------------
# ML Model
# ------------------------------------------------------------
# Đường dẫn tới file .h5 đã train (tương đối so với thư mục backend/)
# Chạy ml/src/train.py trước để tạo file này
MODEL_PATH=ml/models/lstm_v1.h5

# Ngưỡng confidence tối thiểu để chấp nhận prediction (0.0 – 1.0)
CONFIDENCE_THRESHOLD=0.70

# Tỉ lệ window confident tối thiểu để xuất chẩn đoán cuối session
MIN_CONFIDENT_RATIO=0.50


# ------------------------------------------------------------
# FastAPI
# ------------------------------------------------------------
DEBUG=false
APP_TITLE=Smart Insole API
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# Origins được phép gọi API — thêm IP của PC bác sĩ nếu cần
# Ví dụ nhiều origin: http://localhost:3000,http://192.168.1.10:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ------------------------------------------------------------
# WebSocket
# ------------------------------------------------------------
# Số sample tích lũy trước khi tạo 1 window (= WINDOW_SIZE trong preprocess.py)
WS_BUFFER_SIZE=100

# Số WebSocket connections đồng thời tối đa
WS_MAX_CONNECTIONS=10


# ------------------------------------------------------------
# Sensor hardware
# ------------------------------------------------------------
SENSOR_SAMPLE_RATE_HZ=50
ADC_ADS1115_MAX=32767
ADC_ESP32_MAX=4095


# ============================================================
# InfluxDB initial setup (chỉ dùng khi InfluxDB chạy lần đầu)
# Docker Compose đọc các biến này để tự tạo org, bucket, user
# ============================================================
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=smartinsole_influx_pass
DOCKER_INFLUXDB_INIT_ORG=smartinsole
DOCKER_INFLUXDB_INIT_BUCKET=sensor_data
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=smart-insole-dev-token-change-in-production
